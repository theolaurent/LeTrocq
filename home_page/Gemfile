source "https://rubygems.org"

# Modern Jekyll (4.x), not the `github-pages` gem: the docs workflow builds and deploys the site
# itself (it does NOT go through GitHub's Jekyll pipeline), and `github-pages` pins jekyll 3.9.x,
# whose native deps do not install on the Ruby 3.4 that docgen-action forces. Jekyll 4 uses the
# prebuilt sass-embedded, so it builds cleanly on Ruby 3.4.
gem "jekyll", "~> 4.3"
gem "jekyll-remote-theme"    # pulls the pages-themes/cayman look set in _config.yml
gem "jekyll-github-metadata" # site.github.* used by _layouts/default.html
gem "jekyll-seo-tag"         # the {% seo %} tag in _layouts/default.html
gem "webrick"                # for `jekyll serve` locally
